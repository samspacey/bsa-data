# Frontend environment variables (Vite).
# Leave blank / unset for local dev — the Vite dev-server proxy will route
# /api/* to http://localhost:8000 (see vite.config.ts).
#
# In production (Vercel), set this to the deployed backend's origin —
# e.g. https://bsa-backend-production.up.railway.app
VITE_API_BASE=
