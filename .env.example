# BSA Voice of Customer - Environment Variables

# OpenAI API Key (required)
OPENAI_API_KEY=sk-your-key-here

# Optional: Override default model
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional: Scraping configuration
# SCRAPE_DELAY_SECONDS=2.0
# MAX_RETRIES=3

# Optional: Data collection window
# DATA_START_DATE=2020-01-01
# DATA_END_DATE=2026-12-31

# --- Phase 1 new sources (optional; leave blank to skip those scrapers) ---

# Reddit (script-type OAuth app at https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# REDDIT_USER_AGENT=bsa-voc-scraper/0.1 by parklands-internal-research

# SerpAPI key (for Google Reviews). Pricing ~$75/5000 searches.
SERPAPI_KEY=
