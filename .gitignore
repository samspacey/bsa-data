# Local data — too large or too dynamic for git.
# bsa.db (SQLite, ~22MB) IS tracked intentionally for demo reproducibility.
# LanceDB vectors (~205MB, compacted) ARE tracked so Railway builds work
# without a separate embedding-rebuild step.
data/db/*.db-journal
data/db/bsa_reviews.db
# Vercel
frontend/.vercel/
